{
  "name": "@repo/core",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": {
      "types": "./src/*/index.ts",
      "default": "./src/*/index.ts"
    },
    "./drizzle": {
      "types": "./src/drizzle/index.ts",
      "default": "./src/drizzle/index.ts"
    },
    "./error": {
      "types": "./src/error.ts",
      "default": "./src/error.ts"
    },
    "./actor": {
      "types": "./src/actor.ts",
      "default": "./src/actor.ts"
    },
    "./context": {
      "types": "./src/context.ts",
      "default": "./src/context.ts"
    },
    "./event": {
      "types": "./src/event.ts",
      "default": "./src/event.ts"
    }
  },
  "scripts": {
    "exec-vitest": "vitest",
    "test": "bun run scripts/run-integration-tests.ts",
    "test:watch": "bun run scripts/run-integration-tests.ts -- watch",
    "test:db:up": "docker compose -p desktech-core-test -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -p desktech-core-test -f docker-compose.test.yml down -v",
    "test:migrate": "bun run src/drizzle/migrate.ts",
    "test:docker:down": "docker compose -p desktech-core-test -f docker-compose.test.yml down -v",
    "lint": "oxlint --max-warnings 0 --threads 1",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "create-admin": "bun run src/cli/create-admin.ts"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.4",
    "@better-auth-extended/onboarding": "^0.1.1",
    "@hono/zod-validator": "^0.7.6",
    "@better-auth/infra": "^0.1.8",
    "better-auth": "^1.5.4",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.38.3",
    "hono": "4.12.5",
    "pg": "^8.13.1",
    "resend": "^4.0.1",
    "sst": "^4.2.2",
    "ulid": "^2.3.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.9",
    "oxlint": "^1.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
