# Copy to repo root as `.env` (packages/core drizzle loads ../../.env)

# Postgres URL for local scripts / tests. Deployed stages use SST secret `DatabaseUrl`:
#   bunx sst secret set DatabaseUrl "postgresql://..." --stage <stage>

# Optional: local Postgres or when not using `sst shell` (Drizzle CLI, create-admin)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/starter"

DRIZZLE_LOG=false

# Better Auth — use a 32+ char secret in production
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://127.0.0.1:3001

FRONTEND_URL=http://localhost:3000
API_URL=http://127.0.0.1:3001

# Optional: transactional email (verification / password reset)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM="App <noreply@example.com>"
# APP_NAME=My Product

# First admin (bun run create-admin in packages/core)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=

# Vite / browser — only VITE_* is exposed. Copy these into apps/app/.env.local as needed.
# VITE_API_URL=http://127.0.0.1:3001
